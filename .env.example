# Copy to .env (repo root). All values below are the local-dev defaults.

DATABASE_URL=postgres://minivercel:minivercel@127.0.0.1:5432/minivercel
REDIS_URL=redis://127.0.0.1:6379

API_PORT=4000
# Auth token for the control-plane API. Change this before the VPS goes live.
DEPLOY_API_TOKEN=dev-token-change-me

# Build pipeline
BUILD_TIMEOUT_MS=600000
# Where the worker clones repos while building (cleaned up after each build)
BUILD_ROOT=

# CLI
DEPLOY_API_URL=http://127.0.0.1:4000
