# Copy to .env (repo root). All values below are the local-dev defaults.

DATABASE_URL=postgres://minivercel:minivercel@127.0.0.1:5432/minivercel
REDIS_URL=redis://127.0.0.1:6379

API_PORT=4000
# Auth token for the control-plane API. Change this before the VPS goes live.
DEPLOY_API_TOKEN=dev-token-change-me

# Secret for GitHub push-to-deploy webhooks (set the same value on the repo's
# webhook: Settings -> Webhooks -> Secret). Leave empty to disable the endpoint.
GITHUB_WEBHOOK_SECRET=

# Basic-auth password for the dashboard (any username). Empty = no login
# prompt, fine locally — REQUIRED before the dashboard is reachable from
# the internet.
DASHBOARD_PASSWORD=

# Only repos under these GitHub owners can be registered (comma-separated).
# The dashboard's repo picker also lists these owners' public repos.
# Local paths are additionally allowed while DEPLOY_BASE_DOMAIN=localhost.
ALLOWED_REPO_OWNERS=mhmalam

# Build pipeline
BUILD_TIMEOUT_MS=600000
# Where the worker clones repos while building (cleaned up after each build)
BUILD_ROOT=

# Routing (nginx). Local dev serves http://<project>.localhost:8080;
# on the VPS set: DEPLOY_BASE_DOMAIN=deploy.malam.me, DEPLOY_PUBLIC_SCHEME=https,
# DEPLOY_PUBLIC_PORT_SUFFIX= (empty), and NGINX_CONF_DIR to the mounted conf dir.
DEPLOY_BASE_DOMAIN=localhost
DEPLOY_PUBLIC_SCHEME=http
DEPLOY_PUBLIC_PORT_SUFFIX=:8080
NGINX_CONF_DIR=
NGINX_CONTAINER=mini-vercel-nginx

# CLI
DEPLOY_API_URL=http://127.0.0.1:4000
